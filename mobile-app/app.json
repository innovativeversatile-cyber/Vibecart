{
  "expo": {
    "name": "VibeCart",
    "slug": "vibecart-mobile",
    "version": "1.0.9",
    "orientation": "portrait",
    "scheme": "vibecart",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#070b17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecart.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "VibeCart uses notifications for order updates, messages, and security alerts."
      }
    },
    "android": {
      "package": "com.vibecart.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#070b17"
      },
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "vibecartBaseUrl": "https://vibe-cart.com",
      "vibecartApiBaseUrl": "https://vibe-cart.com",
      "vibecartWebCacheTag": "v1-0-9-webview-viewport",
      "eas": {
        "projectId": "c2e55852-2892-4eeb-a6f7-6034e1df8b45"
      }
    }
  }
}
