{
  "expo": {
    "name": "VibeCart",
    "slug": "vibecart-mobile",
    "version": "1.0.8",
    "orientation": "portrait",
    "scheme": "vibecart",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#070b17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecart.mobile",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "VibeCart uses notifications for order updates, messages, and security alerts."
      }
    },
    "android": {
      "package": "com.vibecart.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#070b17"
      },
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "vibecartBaseUrl": "https://vibe-cart.com",
      "vibecartApiBaseUrl": "https://vibe-cart.com",
      "vibecartWebCacheTag": "v1-0-8-smooth-splash"
    }
  }
}
