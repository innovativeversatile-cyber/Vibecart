# Backend runtime
PORT=8081

# --- Railway MySQL (recommended) ---
# On Railway, your Node service usually gets MYSQL_URL when MySQL is linked (no .env needed in production).
# From your PC: Railway → MySQL service → Connect → copy the public TCP URL and set ONE of:
# MYSQL_PUBLIC_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Never put ${{MYSQLUSER}}-style references here — Node does not expand them; you get ECONNREFUSED to 127.0.0.1.
# Never use Railway/CI-only helpers like ${{ secret(...) }} in .env — they are not evaluated locally; MySQL will reject the login.
# (If set, this overrides DB_HOST / DB_PASSWORD / DB_NAME below for mysql2.)
#
# Run migrations with Railway-injected vars (after `npx @railway/cli login` + `railway link` in this folder):
#   npm run db:ensure-mobile-feedback:railway
# Full schema (after empty / wiped DB): `npm run db:apply-schema` (uses `.env` DB_*; wraps FK checks for import).
# Demo shops + live catalog rows: `npm run db:seed` (same DB credentials; safe to re-run).

# Local MySQL or discrete Railway variables (used when no MYSQL_* URL is set)
# For Railway public TCP (*.rlwy.net), TLS is enabled automatically; set DB_SSL=false to force plain TCP.
# On Railway, copy MYSQLUSER / MYSQLPASSWORD / MYSQLHOST / MYSQLPORT / MYSQLDATABASE from the MySQL service Variables tab.
# When MYSQLUSER / MYSQLPASSWORD are set here, they override DB_USER / DB_PASSWORD.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=vibecart_app
DB_PASSWORD=replace-with-strong-password
DB_NAME=vibecart

# Required secret for cron endpoints
CRON_SECRET=replace-with-long-random-secret

# Admin email notification settings
NOTIFICATION_EMAIL=1vibe.cart@gmail.com
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=1vibe.cart@gmail.com
SMTP_PASS=replace-with-gmail-app-password
SMTP_FROM=VibeCart Alerts <1vibe.cart@gmail.com>

# Public "email me the logo" (POST /api/public/brand/email-logo). Uses SMTP_* above. Rate-limited per IP.
BRAND_LOGO_EMAIL_ENABLED=false

# AI operations automation
# AI ops autopilot (queues recommendations on a timer). Defaults ON when NODE_ENV=production; set false to turn off.
AI_AUTOPILOT_ENABLED=true
AI_AUTOPILOT_INTERVAL_MINUTES=120
AI_AUTOPILOT_DEDUPE_HOURS=24

# Payment provider configuration
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret

# Server-only: required when STRIPE_SECRET_KEY is set. Never expose in frontend.
# Call POST /api/public/payments/intent/create with header: X-Payment-Intent-Secret: <this value>
PAYMENT_INTENT_API_SECRET=replace-with-long-random-secret

# Optional: set CORS/reverse proxy values at deployment layer
