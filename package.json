{
  "name": "vibecart",
  "version": "1.0.0",
  "private": true,
  "description": "VibeCart web + owner auth API",
  "main": "owner-auth-api.js",
  "scripts": {
    "start": "node owner-auth-api.js",
    "db:ensure-mobile-feedback": "node scripts/ensure-mobile-app-feedback-table.js",
    "db:ensure-mobile-feedback:railway": "npx --yes @railway/cli run -- npm run db:ensure-mobile-feedback",
    "db:ensure-web-push": "node scripts/ensure-web-push-subscriptions-table.js",
    "db:ensure-web-push:railway": "npx --yes @railway/cli run -- npm run db:ensure-web-push",
    "support:fulfill-coach": "node scripts/fulfill-coach-checkout-support.js",
    "db:apply-schema": "node scripts/apply-schema.js",
    "db:reset-owner": "node -r dotenv/config railway-migrations/20260417_reset_owner_admin_login.js",
    "db:reset-owner:railway": "npx --yes @railway/cli run -- node railway-migrations/20260417_reset_owner_admin_login.js",
    "db:seed": "node scripts/seed-demo.js",
    "db:drop-all-tables": "node scripts/drop-all-tables.js",
    "health:api": "node -e \"fetch('https://vibe-cart.com/api/health').then(r=>r.text().then(t=>console.log('vibe-cart.com/api (proxied)',r.status,t.slice(0,120)))).catch(e=>{console.error('health:api',e.message||e);process.exit(1);})\"",
    "health:site": "node -e \"fetch('https://vibe-cart.com/api/health').then(r=>r.text().then(t=>console.log('vibe-cart.com proxy',r.status,t.slice(0,120)))).catch(e=>{console.error(e);process.exit(1);})\"",
    "health": "node -e \"const u='https://vibe-cart.com/api/health';fetch(u).then(r=>r.text().then(t=>console.log('OK',u,r.status,t.slice(0,100)))).catch(e=>{console.error(e);process.exit(1);})\"",
    "deploy": "node scripts/sync-deploy-web.mjs",
    "deploy:sync": "node scripts/sync-deploy-web.mjs",
    "build": "node scripts/sync-deploy-web.mjs",
    "ship": "node scripts/ship.mjs",
    "health:proxy": "node scripts/check-api-proxy.mjs",
    "health:dns": "node scripts/diagnose-vibe-cart-dns.mjs",
    "smoke:full": "node scripts/run-full-smoke.mjs",
    "smoke:provider-client": "node scripts/hardpass-provider-client.mjs",
    "smoke:provider-client-uiflow": "node scripts/hardpass-provider-client-uiflow.mjs",
    "smoke:homepage-lite": "node scripts/smoke-homepage-lite.mjs",
    "audit:links": "node scripts/audit-static-links.mjs",
    "sweep:market-links": "node scripts/sweep-market-links.mjs",
    "freeze:homepage": "node scripts/homepage-freeze-gate.mjs",
    "readiness:gate": "node scripts/production-readiness-gate.mjs",
    "test:bookings": "node scripts/test-bookings.mjs",
    "test:syntax": "node -e \"require('child_process').execSync('node --check db-env.js',{stdio:'inherit'});require('child_process').execSync('node --check owner-auth-api.js',{stdio:'inherit'});require('child_process').execSync('node --check push-notification-service.js',{stdio:'inherit'});require('child_process').execSync('node --check scripts/ensure-web-push-subscriptions-table.js',{stdio:'inherit'});require('child_process').execSync('node --check scripts/fulfill-coach-checkout-support.js',{stdio:'inherit'});require('child_process').execSync('node --check scripts/apply-schema.js',{stdio:'inherit'});require('child_process').execSync('node --check scripts/seed-demo.js',{stdio:'inherit'});require('child_process').execSync('node --check deploy-web/script.js',{stdio:'inherit'});require('child_process').execSync('node --check deploy-web/admin.js',{stdio:'inherit'});require('child_process').execSync('node --check scripts/diagnose-vibe-cart-dns.mjs',{stdio:'inherit'});require('child_process').execSync('node --check scripts/run-full-smoke.mjs',{stdio:'inherit'});require('child_process').execSync('node --check scripts/hardpass-provider-client.mjs',{stdio:'inherit'});require('child_process').execSync('node --check scripts/hardpass-provider-client-uiflow.mjs',{stdio:'inherit'});require('child_process').execSync('node --check booking-state-machine.js',{stdio:'inherit'});require('child_process').execSync('node --check bakery-booking-payments.js',{stdio:'inherit'});require('child_process').execSync('node --check bakery-realtime.js',{stdio:'inherit'});require('child_process').execSync('node --check payment-service.js',{stdio:'inherit'});require('child_process').execSync('node --check safety-wellness-service.js',{stdio:'inherit'});\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "lenis": "^1.1.18",
    "mysql2": "^3.15.2",
    "nodemailer": "^8.0.5",
    "stripe": "^22.0.2",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  }
}
